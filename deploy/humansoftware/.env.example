# Template de env para el deploy en la VM dev de Humansoftware.
# Copiar a deploy/humansoftware/.env y generar secretos:
#   NEXTAUTH_SECRET:        openssl rand -base64 32
#   CALENDSO_ENCRYPTION_KEY: openssl rand -base64 24  (32 chars para AES256)
#   JWT_SECRET:             openssl rand -base64 32
#   POSTGRES_PASSWORD:      openssl rand -hex 16

POSTGRES_USER=caldiy
POSTGRES_PASSWORD=
POSTGRES_DB=calendso
DATABASE_URL=postgresql://caldiy:${POSTGRES_PASSWORD}@caldiy-db:5432/calendso
DATABASE_DIRECT_URL=${DATABASE_URL}

NEXT_PUBLIC_WEBAPP_URL=http://35.188.238.30:3050
NEXT_PUBLIC_API_V2_URL=http://35.188.238.30:3053/api/v2
NEXTAUTH_URL=${NEXT_PUBLIC_WEBAPP_URL}
NEXTAUTH_SECRET=
CALENDSO_ENCRYPTION_KEY=
JWT_SECRET=

REDIS_URL=redis://caldiy-redis:6379
CALCOM_TELEMETRY_DISABLED=1
NEXT_PUBLIC_LICENSE_CONSENT=agree
NODE_ENV=production

# Integración AGORA (Fase 1): al crear el webhook en cal.diy apuntar a:
#   https://agoracore.humansoftware.mx/webhooks/calcom  (receiver pendiente de PR en agoracore)
